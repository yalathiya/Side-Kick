# Sidekick Configuration
# Copy this file to .env and modify as needed:
#   cp .env.example .env

# Port Sidekick listens on
SIDEKICK_PORT=8081

# Upstream service URL to proxy requests to
SIDEKICK_UPSTREAM_URL=http://localhost:8080

# Rate limiting: tokens added per second (per IP)
SIDEKICK_RATE_LIMIT_RATE=10

# Rate limiting: max burst size (per IP)
SIDEKICK_RATE_LIMIT_BURST=20
