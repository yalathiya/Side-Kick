# Sidekick Configuration
# Copy this file to .env and modify as needed:
#   cp .env.example .env
# Or run: sidekick setup (interactive wizard)

# ---- Core (required) ----
SIDEKICK_PORT=8081
SIDEKICK_UPSTREAM_URL=http://localhost:8080
SIDEKICK_RATE_LIMIT_RATE=10
SIDEKICK_RATE_LIMIT_BURST=20

# ---- JWT Authentication (optional — set secret to enable) ----
# SIDEKICK_JWT_SECRET=your-secret-key
# SIDEKICK_JWT_PUBLIC_KEY=/path/to/rsa-public.pem
# SIDEKICK_JWT_ISSUER=my-auth-service

# ---- Distributed Rate Limiting via Redis (optional) ----
# SIDEKICK_REDIS_URL=redis://localhost:6379
# SIDEKICK_REDIS_DB=0

# ---- Dynamic Config via SQLite (optional) ----
# SIDEKICK_CONFIG_DB=./sidekick.db
# SIDEKICK_CONFIG_RELOAD_INTERVAL=30

# ---- Request Capture / Live Log (optional) ----
# SIDEKICK_CAPTURE_BODIES=false
# SIDEKICK_LOG_BUFFER_SIZE=100
